generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin
  college_manager
  team_member

  @@map("user_role")
}

enum DelegateStatus {
  confirmed
  soft_yes
  cold
  lost

  @@map("delegate_status")
}

enum RegisterOutcome {
  confirmed
  soft_yes
  no_response
  rejected

  @@map("register_outcome")
}

model College {
  id        Int      @id @default(autoincrement())
  name      String   @unique @db.VarChar(100)
  code      String   @unique @db.VarChar(20)
  createdAt DateTime @default(now()) @map("created_at")

  users     User[]
  delegates Delegate[]
  schools   School[]

  @@map("colleges")
}

model School {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(100)
  code      String   @db.VarChar(20)
  collegeId Int      @map("college_id")
  createdAt DateTime @default(now()) @map("created_at")

  college     College      @relation(fields: [collegeId], references: [id])
  departments Department[]
  delegates   Delegate[]

  @@unique([collegeId, code])
  @@map("schools")
}

model Department {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(100)
  schoolId  Int      @map("school_id")
  createdAt DateTime @default(now()) @map("created_at")

  school    School     @relation(fields: [schoolId], references: [id])
  delegates Delegate[]

  @@map("departments")
}

model User {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String   @db.VarChar(255)
  email        String   @unique @db.VarChar(255)
  password     String   @db.VarChar(255)
  role         UserRole
  collegeId    Int?     @map("college_id")
  isFirstLogin Boolean  @default(true) @map("is_first_login")
  isActive     Boolean  @default(true) @map("is_active")
  createdById  String?  @map("created_by") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at")

  college      College? @relation(fields: [collegeId], references: [id])
  createdBy    User?    @relation("UserCreatedUsers", fields: [createdById], references: [id])
  createdUsers User[]   @relation("UserCreatedUsers")

  refreshTokens RefreshToken[]

  delegateAssignmentsAsMember DelegateAssignment[] @relation("TeamMember")
  delegateAssignmentsAssigned DelegateAssignment[] @relation("AssignmentAssignedBy")
  delegatesAdded              Delegate[]           @relation("DelegateAddedBy")
  dailyRegisterContacted      DailyRegister[]      @relation("RegisterContactedBy")
  statusHistoryChanged        StatusHistory[]      @relation("StatusChangedBy")

  @@map("users")
}

model Delegate {
  id           String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String
  collegeId    Int            @map("college_id")
  schoolId     Int?           @map("school_id")
  departmentId Int?           @map("department_id")
  contact      String?        @db.VarChar(20)
  notes        String?
  status       DelegateStatus @default(soft_yes)
  addedById    String?        @map("added_by") @db.Uuid
  regNumber    String?        @unique @map("reg_number") @db.VarChar(50)
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @default(now()) @updatedAt @map("updated_at")

  college    College     @relation(fields: [collegeId], references: [id])
  school     School?     @relation(fields: [schoolId], references: [id])
  department Department? @relation(fields: [departmentId], references: [id])
  addedBy    User?       @relation("DelegateAddedBy", fields: [addedById], references: [id])

  assignments    DelegateAssignment[]
  dailyRegisters DailyRegister[]
  statusHistory  StatusHistory[]

  @@index([collegeId])
  @@index([schoolId])
  @@index([departmentId])
  @@index([status])
  @@map("delegates")
}

model DelegateAssignment {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  delegateId   String   @map("delegate_id") @db.Uuid
  teamMemberId String   @map("team_member_id") @db.Uuid
  assignedById String?  @map("assigned_by") @db.Uuid
  assignedAt   DateTime @default(now()) @map("assigned_at")

  delegate   Delegate @relation(fields: [delegateId], references: [id], onDelete: Cascade)
  teamMember User     @relation("TeamMember", fields: [teamMemberId], references: [id], onDelete: Cascade)
  assignedBy User?    @relation("AssignmentAssignedBy", fields: [assignedById], references: [id])

  @@unique([delegateId, teamMemberId])
  @@index([teamMemberId])
  @@index([delegateId])
  @@map("delegate_assignments")
}

model DailyRegister {
  id            String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  delegateId    String          @map("delegate_id") @db.Uuid
  contactedById String?         @map("contacted_by") @db.Uuid
  contactDate   DateTime        @map("contact_date") @db.Date
  wasContacted  Boolean         @default(false) @map("was_contacted")
  outcome       RegisterOutcome?
  notes         String?
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @default(now()) @updatedAt @map("updated_at")

  delegate    Delegate @relation(fields: [delegateId], references: [id], onDelete: Cascade)
  contactedBy User?    @relation("RegisterContactedBy", fields: [contactedById], references: [id])

  @@unique([delegateId, contactDate, contactedById])
  @@index([delegateId, contactDate])
  @@index([contactedById])
  @@map("daily_register")
}

model StatusHistory {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  delegateId  String   @map("delegate_id") @db.Uuid
  oldStatus   String?  @map("old_status") @db.VarChar(50)
  newStatus   String   @map("new_status") @db.VarChar(50)
  changedById String?  @map("changed_by") @db.Uuid
  changedAt   DateTime @default(now()) @map("changed_at")
  notes       String?

  delegate  Delegate @relation(fields: [delegateId], references: [id], onDelete: Cascade)
  changedBy User?    @relation("StatusChangedBy", fields: [changedById], references: [id])

  @@map("status_history")
}

model RefreshToken {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  token     String
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  isRevoked Boolean  @default(false) @map("is_revoked")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@map("refresh_tokens")
}
